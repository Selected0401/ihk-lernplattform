{
  "name": "ihk-lernplattform",
  "version": "2.0.0",
  "description": "Unabhängiges digitales Übungsmaterial für typische Office-Aufgabentypen - iOS App & Web",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve . -p 3000",
    "build": "echo 'Static build - no compilation needed'",
    "cap:init": "npx cap init",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:copy": "npx cap copy",
    "cap:update": "npx cap update ios",
    "ios:build": "npm run cap:sync && npm run cap:open:ios",
    "test": "python3 scripts/validate-learning-objects.py && node scripts/smoke-worker-security.mjs"
  },
  "keywords": [
    "ihk",
    "bueromanagement",
    "lernplattform",
    "excel",
    "word",
    "powerpoint",
    "outlook",
    "pwa",
    "capacitor",
    "ios"
  ],
  "author": "Prüfungskern Büro",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "serve": "^14.2.0"
  },
  "capacitor": {
    "appId": "de.pruefungskern.buero",
    "appName": "Prüfungskern Büro",
    "webDir": ".",
    "bundledWebRuntime": false,
    "ios": {
      "scheme": "PruefungskernBuero"
    }
  },
  "overrides": {
    "tar": "^7.5.2"
  }
}
