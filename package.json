{
  "name": "ihk-lernplattform",
  "version": "2.0.0",
  "description": "IHK Lernplattform für Büromanagement - iOS App & Web",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve . -p 3000",
    "build": "echo 'Static build - no compilation needed'",
    "cap:init": "npx cap init",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:copy": "npx cap copy",
    "cap:update": "npx cap update ios",
    "ios:build": "npm run cap:sync && npm run cap:open:ios",
    "test": "echo 'Tests run in browser' && exit 0"
  },
  "keywords": [
    "ihk",
    "bueromanagement",
    "lernplattform",
    "excel",
    "word",
    "powerpoint",
    "outlook",
    "pwa",
    "capacitor",
    "ios"
  ],
  "author": "Emilia's IHK Lernplattform",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "serve": "^14.2.0"
  },
  "capacitor": {
    "appId": "de.ihk.lernplattform",
    "appName": "IHK Lernplattform",
    "webDir": ".",
    "bundledWebRuntime": false,
    "ios": {
      "scheme": "IHKLernplattform"
    }
  },
  "overrides": {
    "tar": "^7.5.2"
  }
}
